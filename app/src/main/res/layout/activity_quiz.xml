<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Slideshow -->
    <include layout="@layout/background_slideshow"/>

    <!-- Original Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <!-- Top Status Bar Area -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp"/>

        <!-- Progress and Timer Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <!-- Progress Text -->
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1/10"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"/>

            <!-- Timer -->
            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ 30s"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="#80000000"
                android:padding="10dp"/>

        </LinearLayout>

        <!-- Hidden progress bars -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <ProgressBar
            android:id="@+id/timerProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Main Content Area - CENTERED -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Question Card - More Transparent -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#B3006B3F"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="What is the capital of Zambia?"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:padding="24dp"
                        android:lineSpacingExtra="6dp"
                        android:lineSpacingMultiplier="1.2"
                        android:gravity="center"/>

                </androidx.cardview.widget.CardView>

                <!-- Option Buttons - Transparent -->
                <Button
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 1"
                    android:textSize="15sp"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:textAlignment="textStart"
                    android:gravity="start|center_vertical"
                    android:backgroundTint="#99FFFFFF"
                    android:textColor="@color/text_primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 2"
                    android:textSize="15sp"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:textAlignment="textStart"
                    android:gravity="start|center_vertical"
                    android:backgroundTint="#99FFFFFF"
                    android:textColor="@color/text_primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 3"
                    android:textSize="15sp"
                    android:padding="18dp"
                    android:layout_marginBottom="14dp"
                    android:textAlignment="textStart"
                    android:gravity="start|center_vertical"
                    android:backgroundTint="#99FFFFFF"
                    android:textColor="@color/text_primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnOption4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 4"
                    android:textSize="15sp"
                    android:padding="18dp"
                    android:layout_marginBottom="24dp"
                    android:textAlignment="textStart"
                    android:gravity="start|center_vertical"
                    android:backgroundTint="#99FFFFFF"
                    android:textColor="@color/text_primary"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFFFFF"/>

                <!-- Skip Button -->
                <Button
                    android:id="@+id/btnSkip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏭️ SKIP QUESTION"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:padding="12dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>